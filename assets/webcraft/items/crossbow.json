{
  "model": {
    "type": "select",
    "cases": [
      {
        "model": {
          "type": "model",
          "model": "item/crossbow_arrow"
        },
        "when": "arrow"
      },
      {
        "model": {
          "type": "model",
          "model": "item/crossbow_firework"
        },
        "when": "rocket"
      }
    ],
    "fallback": {
      "type": "condition",
      "on_false": {
        "type": "model",
        "model": "item/crossbow"
      },
      "on_true": {
        "type": "range_dispatch",
        "entries": [
          {
            "model": {
              "type": "model",
              "model": "item/crossbow_pulling_1"
            },
            "threshold": 0.58
          },
          {
            "model": {
              "type": "model",
              "model": "item/crossbow_pulling_2"
            },
            "threshold": 1.0
          }
        ],
        "fallback": {
          "type": "model",
          "model": "item/crossbow_pulling_0"
        },
        "property": "crossbow/pull"
      },
      "property": "using_item"
    },
    "property": "charge_type"
  }
}