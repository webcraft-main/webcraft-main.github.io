{
  "model": {
    "type": "select",
    "cases": [
      {
        "model": {
          "type": "condition",
          "on_false": {
            "type": "model",
            "model": "item/light_gray_bundle"
          },
          "on_true": {
            "type": "composite",
            "models": [
              {
                "type": "model",
                "model": "item/light_gray_bundle_open_back"
              },
              {
                "type": "bundle/selected_item"
              },
              {
                "type": "model",
                "model": "item/light_gray_bundle_open_front"
              }
            ]
          },
          "property": "bundle/has_selected_item"
        },
        "when": "gui"
      }
    ],
    "fallback": {
      "type": "model",
      "model": "item/light_gray_bundle"
    },
    "property": "display_context"
  }
}